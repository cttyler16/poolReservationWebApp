@page "/reserve"
@rendermode InteractiveServer
@inject DatabaseHelper Db
@inject ConfirmationState ConfState
@inject NavigationManager Nav
@inject CustomerSessionService CustomerSession
@inject LoginRateLimiter Limiter
@inject IHttpContextAccessor HttpCtx

<PageTitle>Reserve a Time Slot</PageTitle>

@if (!CustomerSession.IsAuthenticated)
{
    <div class="form-card">
        <div class="form-header">
            <h2>🔒 Access Required</h2>
            <p>Enter the access code provided to you to make a reservation</p>
        </div>
        <div class="form-body">
            <label class="form-label-text">Access Code</label>
            <input class="form-input" type="password" @bind="_accessCode"
                   @onkeydown="OnAccessKeyDown" placeholder="Enter access code" />
            @if (!string.IsNullOrEmpty(_accessError))
            {
                <div class="banner banner-error" style="margin-top:10px;">@_accessError</div>
            }
        </div>
        <div class="form-footer">
            <button class="btn-pool-secondary" @onclick='() => Nav.NavigateTo("/")'>Cancel</button>
            <button class="btn-pool" @onclick="TryAccess">Continue</button>
        </div>
    </div>
}
else
{

<div class="form-card">
    <!-- Header -->
    <div class="form-header">
        <h2>Reserve a Time Slot</h2>
        <p>@(_selectedDate.ToString("dddd, MMMM d, yyyy"))</p>
    </div>

    <div class="form-body">

        <!-- Date -->
        <div class="form-section-label">Reservation Date</div>
        <input type="date" class="form-input"
               value="@_selectedDate.ToString("yyyy-MM-dd")"
               min="@DateTime.Today.ToString("yyyy-MM-dd")"
               max="@DateTime.Today.AddDays(14).ToString("yyyy-MM-dd")"
               @onchange="OnDateChanged" />

        <!-- Time -->
        <div class="form-section-label" style="margin-top:14px;">Reservation Time</div>
        <div style="display:flex;gap:12px;">
            <div style="flex:1;">
                <label class="form-label-text">Start Time *</label>
                <select class="form-select" @onchange="OnStartChanged">
                    @foreach (var (label, ts) in _startOptions)
                    {
                        <option value="@ts.ToString()" selected="@(ts == _startTime)">@label</option>
                    }
                </select>
            </div>
            <div style="flex:1;">
                <label class="form-label-text">Duration *</label>
                <select class="form-select" @onchange="OnDurationChanged">
                    @foreach (var (label, val) in _durationOptions)
                    {
                        <option value="@val.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                selected="@(_durationHours == val)">@label</option>
                    }
                </select>
            </div>
        </div>

        <!-- End time preview -->
        @if (_endTime > _startTime)
        {
            var overClose = _endTime > PoolClose;
            <div class="banner @(overClose ? "banner-error" : "banner-info")" style="margin-top:8px;">
                @if (overClose)
                {
                    <span>⚠ Extends past closing time (@DateTime.Today.Add(PoolClose).ToString("h:mm tt")). Choose an earlier start or shorter duration.</span>
                }
                else
                {
                    <span>Your slot: @DateTime.Today.Add(_startTime).ToString("h:mm tt") – @DateTime.Today.Add(_endTime).ToString("h:mm tt")</span>
                }
            </div>
        }

        @if (_hasConflict)
        {
            <div class="banner banner-warn">⚠ This time overlaps an existing reservation. Please choose a different time.</div>
        }

        <!-- Day schedule -->
        <div class="form-section-label" style="margin-top:14px;">Selected Date's Schedule</div>
        <div class="schedule-mini">
            <div class="schedule-mini-inner">
                @foreach (var block in _scheduleBlocks)
                {
                    <div class="sched-block @(block.IsReserved ? "reserved" : "available")">
                        <div class="sched-dot @(block.IsReserved ? "reserved" : "available")"></div>
                        <div>
                            <div style="font-weight:600;color:@(block.IsReserved ? "#BE123C" : "#0F766E")">@block.TimeRangeDisplay</div>
                            <div style="font-size:0.78rem;color:#6B7280;">@(block.IsReserved ? "Reserved" : $"Available – {block.DurationDisplay}")</div>
                        </div>
                    </div>
                }
                @if (!_scheduleBlocks.Any())
                {
                    <div class="sched-block available">
                        <div class="sched-dot available"></div>
                        <div style="color:#0F766E;font-weight:600;">Fully available</div>
                    </div>
                }
            </div>
        </div>

        <hr style="margin:14px 0 8px;" />

        <!-- Contact info -->
        <div class="form-section-label">Your Information</div>

        <label class="form-label-text">Family Name *</label>
        <input class="form-input" @bind="_familyName" maxlength="100" placeholder="e.g. Smith" />

        <label class="form-label-text">Your Name (Contact Person) *</label>
        <input class="form-input" @bind="_contactName" maxlength="100" placeholder="e.g. Jane Smith" />

        <label class="form-label-text">Phone Number *</label>
        <input class="form-input" @bind="_phone" maxlength="25" placeholder="e.g. (555) 123-4567" />

        <label class="form-label-text">Email Address *</label>
        <input class="form-input" @bind="_email" type="email" maxlength="200" placeholder="e.g. jane@example.com" />

        @if (!string.IsNullOrEmpty(_errorMsg))
        {
            <div class="banner banner-error" style="margin-top:12px;">@_errorMsg</div>
        }
    </div>

    <div class="form-footer">
        <button class="btn-pool-secondary" @onclick='() => Nav.NavigateTo("/")'>Cancel</button>
        <button class="btn-pool" @onclick="Submit" disabled="@(!CanSubmit)">Confirm Reservation ✓</button>
    </div>
</div>
}

@code {
    // Access gate
    private string _accessCode  = "";
    private string _accessError = "";
    private string _clientIp    = "unknown";

    [Parameter]
    [SupplyParameterFromQuery(Name = "date")]
    public string? QueryDate { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "start")]
    public string? QueryStart { get; set; }

    private async Task OnAccessKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") TryAccess();
    }

    private void TryAccess()
    {
        _accessError = "";
        if (string.IsNullOrWhiteSpace(_accessCode))
        {
            _accessError = "Please enter the access code.";
            return;
        }

        var key = $"access:{_clientIp}";
        if (Limiter.IsLocked(key))
        {
            var mins = (int)Math.Ceiling(Limiter.LockoutRemaining(key).TotalMinutes);
            _accessError = $"Too many failed attempts. Try again in {mins} minute{(mins == 1 ? "" : "s")}.";
            _accessCode  = "";
            return;
        }

        var hash = Db.GetSetting("access_hash");
        var salt = Db.GetSetting("access_salt");
        if (string.IsNullOrEmpty(hash) || string.IsNullOrEmpty(salt) ||
            !SecurityHelper.VerifyPin(_accessCode, salt, hash))
        {
            Limiter.RecordFailure(key);
            var remaining = Limiter.AttemptsRemaining(key);
            _accessError = remaining > 0
                ? $"Incorrect access code. {remaining} attempt{(remaining == 1 ? "" : "s")} remaining."
                : $"Too many failed attempts. Try again in {(int)Math.Ceiling(Limiter.LockoutRemaining(key).TotalMinutes)} minutes.";
            _accessCode = "";
            return;
        }

        Limiter.RecordSuccess(key);
        CustomerSession.Authenticate();
        // Initialize form data now that we are authenticated
        (PoolOpen, PoolClose) = Db.GetPoolHours();
        _maxDuration = Db.GetMaxDurationHours();
        BuildDurationOptions();
        BuildStartOptions();
        ApplyQueryParams();
        RefreshSchedule();
        UpdateEndTime();
    }

    // Reservation form
    private TimeSpan PoolOpen;
    private TimeSpan PoolClose;
    private double   _maxDuration = 2.0;

    private DateTime _selectedDate = DateTime.Today;
    private TimeSpan _startTime;
    private double   _durationHours = 1.0;
    private TimeSpan _endTime;
    private bool     _hasConflict;
    private bool     _overClose;

    private string _familyName  = "";
    private string _contactName = "";
    private string _phone       = "";
    private string _email       = "";
    private string _errorMsg    = "";

    private List<(string label, TimeSpan ts)>    _startOptions    = [];
    private List<(string label, double val)>      _durationOptions = [];
    private List<ScheduleBlock>                   _scheduleBlocks  = [];

    private bool CanSubmit => !_hasConflict && !_overClose && _endTime > _startTime;

    protected override void OnInitialized()
    {
        _clientIp = HttpCtx.HttpContext?.Connection.RemoteIpAddress?.ToString()
                    ?? HttpCtx.HttpContext?.Request.Headers["X-Forwarded-For"].FirstOrDefault()
                    ?? "unknown";

        // If already authenticated (e.g. navigated away and back), load form data.
        if (CustomerSession.IsAuthenticated)
        {
            (PoolOpen, PoolClose) = Db.GetPoolHours();
            _maxDuration = Db.GetMaxDurationHours();
            BuildDurationOptions();
            BuildStartOptions();
            ApplyQueryParams();
            RefreshSchedule();
            UpdateEndTime();
        }
    }

    private void ApplyQueryParams()
    {
        if (!string.IsNullOrEmpty(QueryDate) &&
            DateTime.TryParse(QueryDate, out var d) &&
            d >= DateTime.Today && d <= DateTime.Today.AddDays(14))
        {
            _selectedDate = d;
        }

        if (!string.IsNullOrEmpty(QueryStart) &&
            TimeSpan.TryParse(QueryStart, out var ts))
        {
            // Snap to the nearest available start option
            var match = _startOptions.FirstOrDefault(o => o.ts == ts);
            if (match != default) _startTime = match.ts;
        }
    }

    private void BuildDurationOptions()
    {
        _durationOptions.Clear();
        for (double h = 0.5; h <= _maxDuration + 0.001; h += 0.5)
        {
            var label = h == Math.Floor(h)
                ? $"{(int)h} {(h == 1.0 ? "hour" : "hours")}"
                : $"{h:F1} hours";
            _durationOptions.Add((label, h));
        }
        // Clamp current selection to the allowed max
        if (_durationHours > _maxDuration)
            _durationHours = _durationOptions.Last().val;
    }

    private void BuildStartOptions()
    {
        _startOptions.Clear();
        var latest = PoolClose - TimeSpan.FromHours(0.5);
        var t = PoolOpen;
        while (t <= latest)
        {
            _startOptions.Add((DateTime.Today.Add(t).ToString("h:mm tt"), t));
            t = t.Add(TimeSpan.FromMinutes(30));
        }
        _startTime = _startOptions.FirstOrDefault().ts;
    }

    private void OnDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var d))
        {
            if (d < DateTime.Today) d = DateTime.Today;
            if (d > DateTime.Today.AddDays(14)) d = DateTime.Today.AddDays(14);
            _selectedDate = d;
            RefreshSchedule();
            UpdateEndTime();
        }
    }

    private void OnStartChanged(ChangeEventArgs e)
    {
        if (TimeSpan.TryParse(e.Value?.ToString(), out var ts))
        {
            _startTime = ts;
            UpdateEndTime();
        }
    }

    private void OnDurationChanged(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(),
                System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out var d))
        {
            _durationHours = d;
            UpdateEndTime();
        }
    }

    private void UpdateEndTime()
    {
        _endTime   = _startTime + TimeSpan.FromHours(_durationHours);
        _overClose = _endTime > PoolClose;
        _hasConflict = !_overClose && Db.HasConflict(_selectedDate, _startTime, _endTime);
    }

    private void RefreshSchedule()
    {
        _scheduleBlocks.Clear();
        var reservations = Db.GetReservationsForDate(_selectedDate)
                              .OrderBy(r => r.StartTime)
                              .ToList();
        var cursor = PoolOpen;
        foreach (var res in reservations)
        {
            if (res.StartTime > cursor)
                _scheduleBlocks.Add(new ScheduleBlock { StartTime = cursor, EndTime = res.StartTime, IsReserved = false });
            _scheduleBlocks.Add(new ScheduleBlock { StartTime = res.StartTime, EndTime = res.EndTime, IsReserved = true, Reservation = res });
            cursor = res.EndTime;
        }
        if (cursor < PoolClose)
            _scheduleBlocks.Add(new ScheduleBlock { StartTime = cursor, EndTime = PoolClose, IsReserved = false });
    }

    private void Submit()
    {
        _errorMsg = "";

        if (string.IsNullOrWhiteSpace(_familyName))  { _errorMsg = "Please enter your family name.";           return; }
        if (string.IsNullOrWhiteSpace(_contactName)) { _errorMsg = "Please enter the contact person's name."; return; }
        if (string.IsNullOrWhiteSpace(_phone))       { _errorMsg = "Please enter a phone number.";            return; }
        if (!System.Text.RegularExpressions.Regex.IsMatch(_phone.Trim(), @"^[\d\s\-\+\(\)\.]{7,25}$"))
            { _errorMsg = "Please enter a valid phone number."; return; }
        if (string.IsNullOrWhiteSpace(_email))       { _errorMsg = "Please enter an email address.";          return; }
        if (!System.Text.RegularExpressions.Regex.IsMatch(_email.Trim(), @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
            { _errorMsg = "Please enter a valid email address."; return; }

        if (Db.HasConflict(_selectedDate, _startTime, _endTime))
        {
            _errorMsg = "This slot was just taken. Please pick a different time.";
            UpdateEndTime();
            RefreshSchedule();
            return;
        }

        var pin  = SecurityHelper.GeneratePin();
        var salt = SecurityHelper.GenerateSalt();
        var code = SecurityHelper.GenerateConfirmationCode();

        var reservation = new Reservation
        {
            FamilyName       = _familyName.Trim(),
            ContactName      = _contactName.Trim(),
            Phone            = _phone.Trim(),
            Email            = _email.Trim().ToLowerInvariant(),
            Date             = _selectedDate,
            StartTime        = _startTime,
            EndTime          = _endTime,
            PinHash          = SecurityHelper.HashPin(pin, salt),
            PinSalt          = salt,
            ConfirmationCode = code,
            CreatedAt        = DateTime.UtcNow
        };

        Db.CreateReservation(reservation);

        ConfState.Set(reservation, pin);
        Nav.NavigateTo("/confirmation");
    }
}
